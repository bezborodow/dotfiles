#!/usr/bin/env bash
set -eu

# Prints a wide sectional banner.
# @param $1 Banner title.
banner()
{
    # Get terminal column width.
    local cols
    cols=$(tput cols 2>/dev/null || echo 80)

    printf '\n\033[1;35m' # Purple.

    printf '%*s\n' "$cols" '' | tr ' ' '='
    printf '%s\n' "$1"
    printf '%*s\n' "$cols" '' | tr ' ' '='

    printf '\033[0m\n' # Reset.
}

RUN_SYSTEM=0
RUN_USER=0
RUN_GNOME=0

# Check options.
while getopts "sugh" opt; do
  case "$opt" in
    s) RUN_SYSTEM=1 ;;
    u) RUN_USER=1 ;;
    g) RUN_GNOME=1 ;;
    h)
      echo "Usage: $0 [-s] [-u] [-g]"
      echo "  no args  -> system + user"
      echo "  -s       -> system only"
      echo "  -u       -> user only"
      echo "  -g       -> include opt-in GNOME tasks"
      echo "  -h       -> help"
      exit 0
      ;;
    *)
      exit 1
      ;;
  esac
done

# Without a system or user selector, run both playbooks.
if [ "$RUN_SYSTEM" -eq 0 ] && [ "$RUN_USER" -eq 0 ]; then
    RUN_SYSTEM=1
    RUN_USER=1
fi

ansible-galaxy role install geerlingguy.nodejs -p ansible/roles/

PLAYBOOK_ARGS=()
if [ "$RUN_GNOME" -eq 1 ]; then
    PLAYBOOK_ARGS+=(--tags all,gnome)
fi

# Run system playbook.
if [ "$RUN_SYSTEM" -eq 1 ]; then
    sudo --validate
    banner "SYSTEM CHANGES"
    sudo ansible-playbook \
        -c local \
        -i ansible/inventory.ini \
        "${PLAYBOOK_ARGS[@]}" \
        ansible/system.yml
fi

# Run user playbook.
if [ "$RUN_USER" -eq 1 ]; then
    banner "USER CHANGES"
    ansible-playbook \
        -i ansible/inventory.ini \
        "${PLAYBOOK_ARGS[@]}" \
        ansible/user.yml
fi
